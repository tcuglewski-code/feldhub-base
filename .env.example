# ============================================================
# AppFabrik Base — Environment Configuration
# ============================================================
# Kopiere diese Datei nach .env und fülle alle Werte aus:
#   cp .env.example .env
# ============================================================

# === PFLICHT: Datenbank ===
# PostgreSQL Connection String (Neon empfohlen)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# === PFLICHT: Authentication ===
# NextAuth.js Secret (mindestens 32 Zeichen)
# Generieren: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Basis-URL der Anwendung
NEXTAUTH_URL="http://localhost:3000"

# === PFLICHT: Tenant ===
# Aktiver Tenant (muss als Datei in src/config/tenants/ existieren)
TENANT_ID="demo"

# === OPTIONAL: App-Authentifizierung ===
# JWT Secret für Mobile App API-Calls (separates Secret)
APP_JWT_SECRET=""

# Setup-Wizard für Erstinstallation aktivieren
SETUP_ENABLED="false"

# Admin-Email für System-Benachrichtigungen
ADMIN_EMAIL=""

# === OPTIONAL: Email (SMTP) ===
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@appfabrik.de"

# === OPTIONAL: WordPress Integration ===
# WP Admin Credentials (Application Password verwenden!)
WP_USER=""
WP_PASSWORD=""

# Shared Secret für ForstManager ↔ WordPress Sync
WP_FM_SECRET=""

# === OPTIONAL: Nextcloud (Dateispeicher) ===
NEXTCLOUD_URL=""
NEXTCLOUD_USER=""
NEXTCLOUD_PASS=""

# === OPTIONAL: KI & RAG ===
# Perplexity API für intelligente Recherche
PERPLEXITY_API_KEY=""

# Second Brain PostgreSQL (pgvector für Embeddings)
SECOND_BRAIN_URL=""

# === OPTIONAL: Sicherheit ===
# Bearer Token für /api/cron/* Routes
CRON_SECRET=""

# Vercel Automation Bypass Token
VERCEL_BYPASS_TOKEN=""

# === OPTIONAL: Demo-Modus ===
# Demo-Login Passwort (nur für Präsentationen)
DEMO_PASSWORD=""

# === NODE_ENV ===
# development | production | test
NODE_ENV="development"
