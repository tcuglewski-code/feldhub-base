generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// APPFABRIK BASE — Generisches Multi-Tenant Field Service Management
// Version: 2.0.0 (Generisch)
// ============================================================
// Core-Models: User, Project, Task, TimeEntry, Invoice, Document
// Alle Models haben tenantId als Pflichtfeld (außer Tenant selbst)
// ============================================================

// ========== TENANT ==========
model Tenant {
  id           String   @id @default(cuid())
  name         String                          // "Koch Aufforstung GmbH"
  slug         String   @unique                // "koch-aufforstung"
  logo         String?
  primaryColor String   @default("#2C3A1C")
  domain       String?                         // "forstmanager.koch-aufforstung.de"
  timezone     String   @default("Europe/Berlin")
  locale       String   @default("de")
  currency     String   @default("EUR")
  industry     String?                         // "forestry", "landscaping", "cleaning", etc.
  config       Json?                           // Tenant-spezifische Konfiguration
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
}

// ========== USER (Core-Model) ==========
model User {
  id          String   @id @default(cuid())
  tenantId    String                           // PFLICHT: Multi-Tenant
  email       String
  password    String
  name        String
  role        String   @default("worker")      // admin, manager, worker, viewer
  avatar      String?
  phone       String?
  active      Boolean  @default(true)
  permissions String[] @default([])            // Feingranulare Berechtigungen
  lastLoginAt DateTime?
  settings    Json?                            // User-spezifische Einstellungen

  // 2FA Felder
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sessions     Session[]
  teamMember   TeamMember?
  timeEntries  TimeEntry[]
  documents    Document[]      @relation("DocumentCreator")
  tasks        Task[]          @relation("TaskAssignee")
  comments     Comment[]
  activityLogs ActivityLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Session {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([token])
}

// ========== TEAM / MITARBEITER ==========
model TeamMember {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String?  @unique               // Verknüpfung zu User (optional für externe)
  firstName     String
  lastName      String
  email         String?
  phone         String?
  mobile        String?
  address       String?
  zipCode       String?
  city          String?
  birthDate     DateTime?
  hireDate      DateTime?
  terminationDate DateTime?
  role          String   @default("worker")    // team_lead, worker, seasonal, external
  status        String   @default("active")    // active, inactive, on_leave
  hourlyRate    Float?
  fullCostRate  Float?                         // Vollkostenrechnung
  notes         String?
  emergencyContact      String?
  emergencyPhone        String?
  bankName      String?
  iban          String?
  metadata      Json?                          // Branchenspezifische Felder

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User?    @relation(fields: [userId], references: [id])
  teamGroups    TeamGroupMember[]
  timeEntries   TimeEntry[]
  absences      Absence[]
  documents     Document[]  @relation("DocumentOwner")

  @@index([tenantId])
  @@index([tenantId, status])
}

// ========== TEAM-GRUPPEN ==========
model TeamGroup {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  leaderId    String?                          // TeamMember ID
  status      String   @default("active")
  seasonId    String?                          // Optional: Saison-Zuordnung
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  season      Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  members     TeamGroupMember[]
  projects    Project[]
  tasks       Task[]

  @@index([tenantId])
}

model TeamGroupMember {
  id           String     @id @default(cuid())
  tenantId     String
  groupId      String
  memberId     String
  role         String     @default("member")   // leader, member
  group        TeamGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member       TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([groupId, memberId])
  @@index([tenantId])
}

// ========== PROJECT (Core-Model) ==========
// Generisch: kann Auftrag, Projekt, Job, Baustelle etc. sein
model Project {
  id            String   @id @default(cuid())
  tenantId      String
  number        String?                        // Auto: PRJ-2026-0001
  title         String
  type          String                         // Konfigurierbar per Tenant (z.B. "planting", "maintenance")
  status        String   @default("draft")     // draft, active, completed, cancelled
  description   String?
  priority      String   @default("normal")    // low, normal, high, urgent

  // Kunde
  customerName  String?
  customerEmail String?
  customerPhone String?
  customerAddress String?

  // Location
  location      String?
  address       String?
  latitude      Float?
  longitude     Float?
  region        String?                        // Bundesland, Kanton, etc.

  // Zeitplanung
  startDate     DateTime?
  endDate       DateTime?
  deadline      DateTime?

  // Zuordnung
  teamGroupId   String?
  seasonId      String?

  // Berechnung
  estimatedHours Float?
  actualHours    Float?
  estimatedCost  Float?
  actualCost     Float?

  notes         String?
  metadata      Json?                          // Branchenspezifische Felder

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  teamGroup     TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  season        Season?    @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  tasks         Task[]
  timeEntries   TimeEntry[]
  documents     Document[]
  invoices      Invoice[]
  logs          ProjectLog[]
  dailyReports  DailyReport[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
}

model ProjectLog {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  action    String
  fromValue String?
  toValue   String?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
}

// ========== TASK (Core-Model) ==========
model Task {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String?
  assigneeId   String?                         // User ID
  teamGroupId  String?

  title        String
  description  String?
  type         String   @default("general")    // Konfigurierbar
  status       String   @default("todo")       // todo, in_progress, done, cancelled
  priority     String   @default("normal")     // low, normal, high, urgent

  dueDate      DateTime?
  startDate    DateTime?
  completedAt  DateTime?

  estimatedHours Float?
  actualHours    Float?

  // Checklist (optional)
  checklist    Json?                           // [{id, text, done}]

  position     Int      @default(0)            // Für Sortierung
  metadata     Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  teamGroup    TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  comments     Comment[]
  timeEntries  TimeEntry[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([projectId])
  @@index([assigneeId])
}

// ========== TIME ENTRY (Core-Model) ==========
model TimeEntry {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?                         // User der einträgt
  memberId     String?                         // TeamMember (kann ohne User sein)
  projectId    String?
  taskId       String?

  date         DateTime
  hours        Float
  type         String   @default("work")       // work, travel, break, overtime
  description  String?

  hourlyRate   Float?                          // Übernommen von TeamMember oder überschrieben
  bonus        Float?                          // Zuschläge (Maschinen, Nacht, etc.)
  approved     Boolean  @default(false)
  approvedAt   DateTime?
  approvedBy   String?

  // GPS
  startLat     Float?
  startLng     Float?
  endLat       Float?
  endLng       Float?

  metadata     Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  member       TeamMember? @relation(fields: [memberId], references: [id], onDelete: Cascade)
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task         Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([memberId])
  @@index([projectId])
}

// ========== INVOICE (Core-Model) ==========
model Invoice {
  id             String   @id @default(cuid())
  tenantId       String
  projectId      String?
  number         String                        // RE-2026-0001
  status         String   @default("draft")    // draft, sent, paid, overdue, cancelled
  
  invoiceDate    DateTime @default(now())
  dueDate        DateTime?
  paidAt         DateTime?

  subtotal       Float                         // Netto
  taxRate        Float    @default(19)         // MwSt-Satz
  taxAmount      Float                         // MwSt-Betrag
  discount       Float    @default(0)          // Rabatt
  total          Float                         // Brutto

  // Kunde (kann von Project übernommen werden)
  customerName   String?
  customerEmail  String?
  customerAddress String?

  paymentTerms   String?  @default("30 Tage netto")
  notes          String?
  pdfUrl         String?

  metadata       Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items          InvoiceItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  tenantId     String
  invoiceId    String
  description  String
  quantity     Float
  unit         String   @default("Stück")
  unitPrice    Float
  total        Float
  type         String   @default("service")    // service, material, other
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ========== DOCUMENT (Core-Model) ==========
model Document {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String?
  ownerId      String?                         // TeamMember ID
  createdById  String?                         // User ID

  name         String
  type         String   @default("other")      // contract, report, photo, invoice, certificate, other
  category     String?
  description  String?
  
  url          String?                         // S3, Nextcloud, etc.
  storagePath  String?                         // Interner Pfad
  mimeType     String?
  size         Int?                            // Bytes
  
  expiresAt    DateTime?                       // Für Zertifikate, Lizenzen
  confidential Boolean  @default(false)
  
  year         Int?
  metadata     Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner        TeamMember? @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy    User?       @relation("DocumentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([projectId])
}

// ========== SEASON (optional, aber für viele Branchen nützlich) ==========
model Season {
  id          String   @id @default(cuid())
  tenantId    String
  name        String                           // "Pflanzsaison 2026" / "Sommer 2026"
  type        String   @default("standard")    // standard, special
  status      String   @default("planning")    // planning, active, completed
  startDate   DateTime?
  endDate     DateTime?
  description String?
  targets     String?                          // Ziele
  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  projects    Project[]
  teamGroups  TeamGroup[]

  @@index([tenantId])
  @@index([tenantId, status])
}

// ========== DAILY REPORT (Tagesprotokoll) ==========
model DailyReport {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String
  createdById  String?
  teamGroupId  String?

  date         DateTime
  status       String   @default("draft")      // draft, submitted, approved

  // Arbeitszeit
  startTime    String?                         // "07:00"
  endTime      String?                         // "16:00"
  breakMinutes Int      @default(0)

  // Leistung (generisch)
  outputAmount Float?                          // Menge
  outputUnit   String?                         // ha, Stück, lfm, m², etc.
  section      String?                         // Abschnitt, Bereich

  // Witterung
  weather      String?
  tempMin      Int?
  tempMax      Int?

  // GPS
  gpsStartLat  Float?
  gpsStartLng  Float?
  gpsEndLat    Float?
  gpsEndLng    Float?

  // Team
  teamCount    Int?
  teamMembers  Json?                           // [{id, name, hours}]

  // Material & Geräte
  materialsUsed Json?                          // [{id, name, quantity}]
  equipmentUsed Json?                          // [{id, name, hours}]

  // Protokoll
  summary      String   @default("")
  issues       String?
  nextSteps    String?
  customerPresent Boolean @default(false)
  customerNotes String?

  // Dokumentation
  photos       Json?                           // [{url, caption}]
  signature    String?                         // Base64 oder URL

  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedBy   String?

  metadata     Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([projectId])
}

// ========== COMMENT ==========
model Comment {
  id        String   @id @default(cuid())
  tenantId  String
  taskId    String?
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([taskId])
}

// ========== ABSENCE ==========
model Absence {
  id        String   @id @default(cuid())
  tenantId  String
  memberId  String
  type      String                             // vacation, sick, unpaid, training
  startDate DateTime
  endDate   DateTime
  approved  Boolean  @default(false)
  approvedBy String?
  notes     String?
  createdAt DateTime @default(now())

  member    TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([memberId])
}

// ========== INVENTORY (Lager) ==========
model InventoryItem {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  sku           String?                        // Artikelnummer
  category      String   @default("material")
  unit          String   @default("piece")     // piece, kg, liter, meter
  quantity      Float    @default(0)
  minQuantity   Float    @default(0)           // Mindestbestand
  location      String?                        // Lagerort
  purchasePrice Float?
  salePrice     Float?
  metadata      Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements     InventoryMovement[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, category])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  tenantId  String
  itemId    String
  type      String                             // in, out, adjust
  quantity  Float
  reference String?                            // Projekt-ID, Lieferant, etc.
  notes     String?
  createdBy String?
  createdAt DateTime @default(now())

  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([itemId])
}

// ========== EQUIPMENT (Fuhrpark & Geräte) ==========
model Equipment {
  id              String   @id @default(cuid())
  tenantId        String
  type            String                       // vehicle, tool, machine
  name            String
  identifier      String?                      // Kennzeichen, Seriennummer
  manufacturer    String?
  model           String?
  year            Int?
  status          String   @default("available") // available, in_use, maintenance, retired
  nextMaintenance DateTime?
  hourlyRate      Float?                       // Für Kostenzurechnung
  hourlySurcharge Float?                       // Zuschlag für Mitarbeiter
  notes           String?
  metadata        Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  maintenanceRecords MaintenanceRecord[]
  assignments        EquipmentAssignment[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  tenantId    String
  equipmentId String
  type        String                           // inspection, repair, service
  description String
  date        DateTime
  cost        Float?
  completed   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
}

model EquipmentAssignment {
  id          String   @id @default(cuid())
  tenantId    String
  equipmentId String
  projectId   String?
  teamGroupId String?
  startDate   DateTime
  endDate     DateTime?
  purpose     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
}

// ========== CONTACT ==========
model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  type      String   @default("other")         // customer, supplier, authority, partner, other
  name      String
  company   String?
  email     String?
  phone     String?
  mobile    String?
  address   String?
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
}

// ========== ACTIVITY LOG ==========
model ActivityLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String                            // create, update, delete, login, etc.
  entityType String                            // Project, Task, Invoice, etc.
  entityId   String
  entityName String?
  changes    Json?                             // {field: {old, new}}
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, entityType])
  @@index([tenantId, createdAt])
}

// ========== SYSTEM CONFIG ==========
model SystemConfig {
  id        String   @id @default(cuid())
  tenantId  String?                            // null = global
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
}

// ========== WEBHOOK (für Integrationen) ==========
model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  url       String
  events    String[]                           // ["project.created", "invoice.paid"]
  secret    String?
  active    Boolean  @default(true)
  lastError String?
  lastSentAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}
